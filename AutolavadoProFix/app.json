{
  "expo": {
    "name": "Autolavado Pro",
    "slug": "autolavadopro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D4ED8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.autolavadopro",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Usamos Face ID para verificar tu identidad como administrador."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1D4ED8"
      },
      "package": "com.autolavadopro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Necesitamos tu ubicación para verificar que estás en el autolavado."
        }
      ],
      "expo-local-authentication"
    ]
  }
}